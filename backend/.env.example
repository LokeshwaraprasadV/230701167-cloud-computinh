### FastAPI
APP_NAME="Eye ROI Analyzer for Diabetic Retinopathy"
ENVIRONMENT="local"
FRONTEND_ORIGIN="http://localhost:5173"

### Local storage (used when Azure not configured)
LOCAL_STORAGE_DIR="storage"
LOCAL_DB_JSON_PATH="storage/db.json"

### Azure Blob Storage (optional)
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_BLOB_CONTAINER_NAME="retina-images"
AZURE_BLOB_PUBLIC_BASE_URL=""

### Azure Cosmos DB (Mongo API) (optional)
COSMOS_MONGO_URI=""
COSMOS_DB_NAME="eye_roi_analyzer"
COSMOS_COLLECTION_NAME="predictions"

### ML model
# Put your trained model here (recommended).
# Example path: backend/app/models/dr_model.keras
MODEL_PATH="app/models/dr_model.keras"

### Reports
REPORTS_DIR="storage/reports"
